MODULE {{ module_name }}
  {{ comment }}
  ! Points: {{ points | length }}
  ! Speed: {{ speed_mms }} mm/s

  PERS tooldata {{ tool_name }} := [TRUE,[[0,0,0],[1,0,0,0]],[0.001,[0,0,0.001],[1,0,0,0],0,0,0]];

  PROC {{ proc_name }}()
    ConfJ \Off;
    ConfL \Off;
{% for pt in points %}
    MoveL [[{{ "%.3f" | format(pt.x) }},{{ "%.3f" | format(pt.y) }},{{ "%.3f" | format(pt.z) }}],[{{ "%.6f" | format(pt.q1) }},{{ "%.6f" | format(pt.q2) }},{{ "%.6f" | format(pt.q3) }},{{ "%.6f" | format(pt.q4) }}],[0,0,0,0],[9E+09,9E+09,9E+09,9E+09,9E+09,9E+09]], v{{ speed_mms | int }}, fine, {{ tool_name }};
{% endfor %}
  ENDPROC
ENDMODULE
