/PROG  {{ program_name }}
/ATTR
OWNER       = MNEDITOR;
COMMENT     = "{{ comment }}";
PROG_SIZE   = 0;
CREATE      = DATE UNKNOWN  TIME UNKNOWN;
MODIFIED    = DATE UNKNOWN  TIME UNKNOWN;
FILE_NAME   = ;
VERSION     = 0;
LINE_COUNT  = {{ points | length }};
MEMORY_SIZE = 0;
PROTECT     = READ_WRITE;
TCD:  STACK_SIZE    = 0,
      TASK_PRIORITY = 50,
      TIME_SLICE    = 0,
      BUSY_LAMP_OFF = 0,
      ABORT_REQUEST = 0,
      PAUSE_REQUEST = 0;
DEFAULT_GROUP  = 1,*,*,*,*;
CONTROL_CODE   = 00000000 00000000;
/APPL
/MN
   1:  UTOOL_NUM={{ utool_num }} ;
   2:  UFRAME_NUM={{ uframe_num }} ;
{% for pt in points %}
   {{ loop.index + 2 }}:{{ motion_type }} P[{{ loop.index }}:point{{ loop.index }}] {{ speed_mms }}mm/sec FINE    ;
{% endfor %}
/POS
{% for pt in points %}
P[{{ loop.index }}:"point{{ loop.index }}"]{
   GP1:
  UF : {{ uframe_num }}, UT : {{ utool_num }},
  X = {{ "%.3f" | format(pt.x) }}  mm, Y = {{ "%.3f" | format(pt.y) }}  mm, Z = {{ "%.3f" | format(pt.z) }}  mm,
  W = {{ "%.3f" | format(pt.rx) }}  deg, P = {{ "%.3f" | format(pt.ry) }}  deg, R = {{ "%.3f" | format(pt.rz) }}  deg
};
{% endfor %}
/END
