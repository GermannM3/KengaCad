<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="KengaCAD.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:KengaCAD.Mobile"
    Title="KengaCAD"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#121212"
    Shell.ForegroundColor="White"
    Shell.TabBarBackgroundColor="#1A1A1A"
    Shell.TabBarTitleColor="#FF6600"
    Shell.TabBarUnselectedColor="#888888">

    <TabBar>
        <ShellContent Title="Jog"
                      Icon="dotnet_bot.png"
                      ContentTemplate="{DataTemplate local:MainPage}"
                      Route="jog" />
        <ShellContent Title="Связь"
                      Icon="dotnet_bot.png"
                      ContentTemplate="{DataTemplate local:ConnectionPage}"
                      Route="link" />
    </TabBar>

</Shell>
