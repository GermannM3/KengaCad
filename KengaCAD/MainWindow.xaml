<Window x:Class="KengaCAD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KengaCAD"
        mc:Ignorable="d"
        Title="KengaCAD Professional v2.2.1" 
        Height="900" Width="1400"
        Background="{StaticResource PrimaryDarkBackground}"
        WindowState="Maximized"
        TextElement.Foreground="White"
        TextElement.FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="NewCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="OpenCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="SaveCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}" Executed="UndoCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Redo}" Executed="RedoCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Delete}" Executed="DeleteCommand_Executed"/>
    </Window.CommandBindings>
    
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Redo}"/>
        <KeyBinding Key="Delete" Command="{x:Static ApplicationCommands.Delete}"/>
    </Window.InputBindings>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ==================== RIBBON PANEL ==================== -->
        <TabControl Grid.Row="0" Style="{StaticResource RibbonTabControlStyle}"
                    ItemContainerStyle="{StaticResource RibbonTabStyle}">
            
            <!-- Вкладка ГЛАВНАЯ -->
            <TabItem Header="Главная">
                <Grid Background="{StaticResource TertiaryDarkBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Панель РИСОВАНИЕ -->
                    <Border Grid.Column="0" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="LINE" Content="Линия"
                                    ToolTip="LINE - Рисование линии (L)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="CIRCLE" Content="Круг"
                                    ToolTip="CIRCLE - Рисование окружности (C)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ARC" Content="Дуга"
                                    ToolTip="ARC - Рисование дуги (A)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="POLYLINE" Content="Полилиния"
                                    ToolTip="POLYLINE - Рисование полилинии (PL)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="RECTANGLE" Content="Прямоугольник"
                                    ToolTip="RECTANGLE - Рисование прямоугольника (REC)"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель РЕДАКТИРОВАНИЕ -->
                    <Border Grid.Column="1" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="MOVE" Content="Переместить"
                                    ToolTip="MOVE - Перемещение объектов (M)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="COPY" Content="Копировать"
                                    ToolTip="COPY - Копирование объектов (CO)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ROTATE" Content="Повернуть"
                                    ToolTip="ROTATE - Поворот объектов (RO)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="SCALE" Content="Масштаб"
                                    ToolTip="SCALE - Масштабирование (SC)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="MIRROR" Content="Зеркало"
                                    ToolTip="MIRROR - Зеркальное отражение (MI)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TRIM" Content="Обрезать"
                                    ToolTip="TRIM - Обрезка до границы (TR)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="EXTEND" Content="Удлинить"
                                    ToolTip="EXTEND - Удлинение до границы (EX)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="FILLET" Content="Скругление"
                                    ToolTip="FILLET - Скругление углов (F)"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель СЛОИ -->
                    <Border Grid.Column="2" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="LAYERNEW" Content="Новый слой"
                                    ToolTip="Создать новый слой"/>
                            <ComboBox x:Name="LayerComboBox" Width="150" 
                                      Background="{StaticResource SecondaryDarkBackground}"
                                      Foreground="White"
                                      Margin="8,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель СВОЙСТВА -->
                    <Border Grid.Column="3" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="ColorComboBox" Width="100" 
                                      Background="{StaticResource SecondaryDarkBackground}"
                                      Foreground="White"
                                      Margin="0,0,8,0"/>
                            <ComboBox x:Name="LineTypeComboBox" Width="120" 
                                      Background="{StaticResource SecondaryDarkBackground}"
                                      Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Вкладка ВИД -->
            <TabItem Header="Вид">
                <Grid Background="{StaticResource TertiaryDarkBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Панель НАВИГАЦИЯ -->
                    <Border Grid.Column="0" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ZOOMEXTENTS" Content="Показать всё"
                                    ToolTip="ZOOM_EXTENTS - Показать все объекты (ZE)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ZOOMIN" Content="Увеличить"
                                    ToolTip="Увеличить масштаб"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ZOOMOUT" Content="Уменьшить"
                                    ToolTip="Уменьшить масштаб"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="PAN" Content="Панорама"
                                    ToolTip="Сдвинуть вид"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель ВИДЫ -->
                    <Border Grid.Column="1" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="VIEWTOP" Content="Сверху"
                                    ToolTip="VIEW_TOP - Вид сверху (VT)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="VIEWFRONT" Content="Спереди"
                                    ToolTip="VIEW_FRONT - Вид спереди (VF)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="VIEWLEFT" Content="Слева"
                                    ToolTip="VIEW_LEFT - Вид слева (VL)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="VIEW3D" Content="3D"
                                    ToolTip="VIEW3D_FULL - Полноценное 3D"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель ОТОБРАЖЕНИЕ -->
                    <Border Grid.Column="2" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="GridCheckBox" Content="Сетка" IsChecked="True" 
                                      Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox x:Name="OrthoCheckBox" Content="Орто" 
                                      Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox x:Name="SnapCheckBox" Content="Привязки" IsChecked="True"
                                      Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Вкладка РОБОТ -->
            <TabItem Header="Робот">
                <Grid Background="{StaticResource TertiaryDarkBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Панель УПРАВЛЕНИЕ -->
                    <Border Grid.Column="0" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="RobotPresetComboBox" Width="180" 
                                      Background="{StaticResource SecondaryDarkBackground}"
                                      Foreground="White" Margin="0,0,8,0"
                                      SelectionChanged="RobotPresetComboBox_SelectionChanged"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="LOADROBOT" Content="Загрузить"
                                    ToolTip="Загрузить робота (из списка или STL/OBJ файл)"
                                    Background="#0078D4" Foreground="White" FontWeight="Bold"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="LOADDEMOROBOT" Content="Демо"
                                    ToolTip="Демо-робот и запуск симуляции траектории"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="ZEROJOINTS" Content="В ноль"
                                    ToolTip="Сбросить все суставы в 0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель ТРАЕКТОРИИ -->
                    <Border Grid.Column="1" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TRAJFROMPOLYLINE" Content="Из полилинии"
                                    ToolTip="TRAC_FROM_POLYLINE - Траектория из полилинии"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TRAJSPLINE" Content="Сплайн"
                                    ToolTip="TRAJ_SPLINE - Кубический сплайн"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TRAJSMOOTH" Content="Сгладить"
                                    ToolTip="TRAJ_SMOOTH - Сглаживание Chaikin"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TRAJSPIRAL" Content="Спираль"
                                    ToolTip="TRAJ_SPIRAL - Спиральная траектория"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель СИМУЛЯЦИЯ -->
                    <Border Grid.Column="2" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="SIMULATE" Content="Старт"
                                    ToolTip="SIMULATE - Запуск симуляции"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="SIMPAUSE" Content="Пауза"
                                    ToolTip="SIM_PAUSE - Пауза"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="SIMSTOP" Content="Стоп"
                                    ToolTip="SIM_STOP - Остановка"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="SIMRESET" Content="Сброс"
                                    ToolTip="SIM_RESET - Сброс"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель ЭКСПОРТ -->
                    <Border Grid.Column="3" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportGCode_Click" Content="G-код"
                                    ToolTip="EXPORT_GCODE - Экспорт в G-код"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportKRL_Click" Content="KUKA KRL"
                                    ToolTip="Экспорт в KUKA KRL (.krl)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportRAPID_Click" Content="ABB RAPID"
                                    ToolTip="Экспорт в ABB RAPID (.mod)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportTP_Click" Content="Fanuc TP"
                                    ToolTip="Экспорт в Fanuc TP (.ls)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportYaskawa_Click" Content="Yaskawa"
                                    ToolTip="Экспорт в Yaskawa INFORM (.jbi)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="ExportUR_Click" Content="UR Script"
                                    ToolTip="Экспорт в Universal Robots (.urp)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="EXPORTCSV" Content="CSV"
                                    ToolTip="Экспорт траектории CSV (RoboCAD)"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="IMPORTCSV" Content="CSV→"
                                    ToolTip="Импорт траектории из CSV"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка СИМУЛЯЦИЯ -->
            <TabItem Header="Симуляция">
                <Grid Background="{StaticResource TertiaryDarkBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="CHECKCOLLISION" Content="Коллизии"
                                    ToolTip="Проверка коллизий траектории и робота"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="CYCLETIME" Content="Время цикла"
                                    ToolTip="Расчёт времени цикла программы"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="SELFCOLLISION" Content="Самоколлизия"
                                    ToolTip="Проверка самоколлизий звеньев робота"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="ADDTABLE" Content="Стол"
                                    ToolTip="Добавить рабочий стол"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="ADDFIXTURE" Content="Оснастка"
                                    ToolTip="Добавить оснастку"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="ADDFENCE" Content="Ограждение"
                                    ToolTip="Добавить ограждение"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="ADDCONVEYOR" Content="Конвейер"
                                    ToolTip="Добавить конвейер"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="ADDROBOT" Content="+ Робот"
                                    ToolTip="Добавить второй робот в ячейку (до 4)"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="CLEARWORKCELL" Content="Очистить ячейку"
                                    ToolTip="Удалить все объекты workcell"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Вкладка ВСТАВКА -->
            <TabItem Header="Вставка">
                <Grid Background="{StaticResource TertiaryDarkBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Панель 3D МОДЕЛИ -->
                    <Border Grid.Column="0" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="IMPORTSTEP" Content="STEP"
                                    ToolTip="Импорт STEP файла"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="IMPORTIGES" Content="IGES"
                                    ToolTip="Импорт IGES файла"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="IMPORTSTL" Content="STL"
                                    ToolTip="Импорт STL файла"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="IMPORTOBJ" Content="OBJ"
                                    ToolTip="Импорт OBJ файла"/>
                            <Button Style="{StaticResource RibbonButtonStyle}"
                                    Click="RibbonCommand_Click" Tag="IMPORTGLTF" Content="glTF"
                                    ToolTip="Импорт glTF/GLB файла"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель БЛОКИ -->
                    <Border Grid.Column="1" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="CREATEBLOCK" Content="Создать блок"
                                    ToolTip="Создать блок из выделенного"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="INSERTBLOCK" Content="Вставить"
                                    ToolTip="Вставить блок"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Панель АННОТАЦИИ -->
                    <Border Grid.Column="2" Padding="8" BorderBrush="#505050" BorderThickness="1,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="TEXT" Content="Текст"
                                    ToolTip="Добавить текст"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="DIMLINEAR" Content="Размер"
                                    ToolTip="Линейный размер"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="DIMRADIUS" Content="Радиус"
                                    ToolTip="Размер радиуса"/>
                            <Button Style="{StaticResource RibbonButtonStyle}" 
                                    Click="RibbonCommand_Click" Tag="EXPORTPDF" Content="PDF"
                                    ToolTip="Экспорт чертежа в PDF"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Основная рабочая область: браузер проекта + CAD/3D сцена + Jog-пульт -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#22252A" BorderBrush="#3A3D42" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2B2F35" Padding="10,8">
                        <TextBlock Text="Проект / Subprograms" FontWeight="SemiBold"/>
                    </Border>
                    <ListBox x:Name="ProjectTreeList" Grid.Row="1" Margin="6"
                             Background="#1B1D22" Foreground="#E6E6E6" BorderBrush="#454A52"/>
                    <Border Grid.Row="2" Background="#252A31" BorderBrush="#3B414A" BorderThickness="0,1,0,0" Padding="6" MaxHeight="200">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Сигналы I/O" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OpcEndpointTextBox" Grid.Column="0" Margin="0,0,4,0"
                                         Text="opc.tcp://localhost:4840" FontSize="10" Padding="4,2"
                                         Background="#161A1F" Foreground="#E6E6E6" BorderBrush="#3B414A"/>
                                <Button Grid.Column="1" Content="OPC" Padding="6,2" Margin="0,0,4,0" FontSize="10"
                                        Click="OpcConnect_Click" ToolTip="Подключить OPC UA"/>
                                <Button Grid.Column="2" Content="X" Padding="6,2" FontSize="10"
                                        Click="OpcDisconnect_Click" ToolTip="Отключить OPC UA"/>
                            </Grid>
                            <TextBlock x:Name="OpcStatusText" Grid.Row="1" VerticalAlignment="Bottom"
                                       FontSize="9" Foreground="#8A9099" Margin="0,22,0,0" Text="OPC: offline"/>
                            <DataGrid x:Name="IoSignalsGrid" Grid.Row="2" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                                      Background="#161A1F" Foreground="#E6E6E6" BorderBrush="#3B414A"
                                      FontSize="10" RowHeight="22" CellEditEnding="IoSignalsGrid_CellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="36"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="24"/>
                                    <DataGridCheckBoxColumn Header="Val" Binding="{Binding Value}" Width="28"/>
                                    <DataGridTextColumn Header="NodeId" Binding="{Binding OpcNodeId}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="6">
                        <Button Content="Новый" Padding="10,4" Margin="0,0,6,0"
                                Command="{x:Static ApplicationCommands.New}"/>
                        <Button Content="Открыть" Padding="10,4" Margin="0,0,6,0"
                                Command="{x:Static ApplicationCommands.Open}"/>
                        <Button Content="Сохранить" Padding="10,4"
                                Command="{x:Static ApplicationCommands.Save}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="#1E1E1E">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="DrawingColumnDefinition" Width="*"/>
                    <ColumnDefinition x:Name="SceneColumnDefinition" Width="460"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Background="#1E1E1E" x:Name="DrawingCanvasHost">
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="#A01F2328" Padding="8,4" Margin="8" CornerRadius="4">
                        <TextBlock Text="2D рабочее поле" Foreground="#A8B0BC" FontSize="11"/>
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Background="#80202020" Padding="8,4" Margin="8" CornerRadius="4">
                        <TextBlock x:Name="CursorInfo" Text="X: 0,00  Y: 0,00"
                                   Foreground="#00FF00" FontFamily="Consolas" FontSize="12"/>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Background="#252525">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="3D рабочая сцена" Margin="8,6,8,2"
                               Foreground="#AAB2BD" FontSize="11"/>
                    <Border Grid.Row="1" x:Name="ViewportBorder" Background="#101729" Margin="4,0,4,0"
                            MouseMove="Viewport3D_MouseMove"
                            MouseRightButtonDown="Viewport3D_MouseRightButtonDown"
                            MouseRightButtonUp="Viewport3D_MouseRightButtonUp"
                            MouseLeftButtonDown="Viewport3D_MouseLeftButtonDown"
                            MouseLeftButtonUp="Viewport3D_MouseLeftButtonUp"
                            MouseWheel="Viewport3D_MouseWheel">
                        <Viewport3D x:Name="Viewport3D">
                            <Viewport3D.Camera>
                                <PerspectiveCamera x:Name="MainCamera"
                                                   Position="800,-800,550"
                                                   LookDirection="-800,800,-550"
                                                   UpDirection="0,0,1"
                                                   FieldOfView="45"/>
                            </Viewport3D.Camera>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="#FFFFFF" Direction="-1,-1,-1"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="#909090" Direction="1,1,0.5"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <AmbientLight Color="#505050"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D x:Name="GridFloor3D"/>
                            <ModelVisual3D x:Name="WorkcellModel3D"/>
                            <ModelVisual3D x:Name="RobotModel"/>
                            <ModelVisual3D x:Name="DrawingOverlay3D"/>
                            <ModelVisual3D x:Name="TrajectoryContainer"/>
                        </Viewport3D>
                    </Border>
                    <Border Grid.Row="2" Background="#30343B" Padding="6" Margin="0,4,0,0">
                        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Content="Изометрия" Margin="2" Padding="8,4" Click="ViewIso_Click"/>
                            <Button Content="Сверху" Margin="2" Padding="8,4" Click="ViewTop_Click"/>
                            <Button Content="Спереди" Margin="2" Padding="8,4" Click="ViewFront_Click"/>
                            <Button Content="Сброс" Margin="2" Padding="8,4" Click="ResetView_Click"/>
                            <Separator Width="12"/>
                            <Button Content="Сброс базы" Margin="2" Padding="8,4" Click="ResetRobotBase_Click"/>
                            <CheckBox x:Name="ThreeDOnlyCheckBox" Content="Только 3D" Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      Checked="ThreeDOnlyCheckBox_Checked"
                                      Unchecked="ThreeDOnlyCheckBox_Unchecked"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="2" Background="#1F2329" BorderBrush="#3A3D42" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2B2F35" Padding="10,8">
                        <TextBlock Text="Jog / Robot" FontWeight="SemiBold"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="8,8,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Робот:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Grid.Column="1" x:Name="JogRobotComboBox" SelectionChanged="JogRobotComboBox_SelectionChanged"
                                  Background="#2D2D30" Foreground="White"
                                  ToolTip="Выбор активного робота в ячейке"/>
                    </Grid>

                    <Border Grid.Row="2" Margin="8,8,8,0" Background="#252A31" BorderBrush="#3B414A" BorderThickness="1" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TCP" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TcpXText" Text="X: 0.00"/>
                                <TextBlock x:Name="TcpYText" Text="Y: 0.00"/>
                                <TextBlock x:Name="TcpZText" Text="Z: 0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ориентация" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TcpRxText" Text="Rx: 0.00"/>
                                <TextBlock x:Name="TcpRyText" Text="Ry: 0.00"/>
                                <TextBlock x:Name="TcpRzText" Text="Rz: 0.00"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="3" Margin="8,8,8,8" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Шаг,°:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" Width="70" x:Name="JogStepComboBox" SelectedIndex="1">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="15"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="В ноль" Margin="8,0,0,0" Padding="10,4"
                                        Click="ZeroJointsButton_Click"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tool:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" x:Name="ToolFrameComboBox" Margin="0,0,8,0"
                                          SelectionChanged="FramesComboBox_SelectionChanged"/>
                                <TextBlock Grid.Column="2" Text="Base:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="3" x:Name="BaseFrameComboBox"
                                          SelectionChanged="FramesComboBox_SelectionChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TCP шаг, мм:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" Width="72" x:Name="TcpStepComboBox" SelectedIndex="1">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="25"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="X-" Tag="X-" Click="TcpJogButton_Click" Margin="8,0,4,0" Padding="8,3"/>
                                <Button Grid.Column="3" Content="X+" Tag="X+" Click="TcpJogButton_Click" Margin="0,0,4,0" Padding="8,3"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Y-" Tag="Y-" Click="TcpJogButton_Click" Margin="0,0,4,0" Padding="8,3"/>
                                <Button Grid.Column="1" Content="Y+" Tag="Y+" Click="TcpJogButton_Click" Margin="0,0,4,0" Padding="8,3"/>
                                <Button Grid.Column="2" Content="Z-" Tag="Z-" Click="TcpJogButton_Click" Margin="0,0,4,0" Padding="8,3"/>
                                <Button Grid.Column="3" Content="Z+" Tag="Z+" Click="TcpJogButton_Click" Padding="8,3"/>
                            </Grid>

                            <Border Background="#20252C" BorderBrush="#3B414A" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Программные точки" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="Добавить текущую TCP" Click="AddWaypointButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Очистить" Click="ClearWaypointsButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Шаг" Click="StepWaypointProgramButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Авто" Click="RunWaypointProgramButton_Click" Padding="8,3"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="Вверх" Click="MoveWaypointUpButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Вниз" Click="MoveWaypointDownButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Удалить" Click="DeleteWaypointButton_Click" Padding="8,3" Margin="0,0,12,0"/>
                                        <TextBlock Text="V, мм/с:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox x:Name="DefaultWaypointSpeedTextBox" Text="120" Width="46" Margin="0,0,10,0"/>
                                        <TextBlock Text="A, мм/с²:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox x:Name="DefaultWaypointAccelTextBox" Text="300" Width="52"/>
                                    </StackPanel>
                                    <DataGrid x:Name="WaypointsGrid" Grid.Row="3" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                                              SelectionMode="Single" Background="#161A1F" Foreground="#E6E6E6"
                                              BorderBrush="#3B414A" SelectionChanged="WaypointsGrid_SelectionChanged"
                                              CellEditEnding="WaypointsGrid_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="38"/>
                                            <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F1}" Width="62"/>
                                            <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F1}" Width="62"/>
                                            <DataGridTextColumn Header="Z" Binding="{Binding Z, StringFormat=F1}" Width="62"/>
                                            <DataGridTextColumn Header="Rx" Binding="{Binding Rx, StringFormat=F1}" Width="54"/>
                                            <DataGridTextColumn Header="Ry" Binding="{Binding Ry, StringFormat=F1}" Width="54"/>
                                            <DataGridTextColumn Header="Rz" Binding="{Binding Rz, StringFormat=F1}" Width="54"/>
                                            <DataGridTextColumn Header="V" Binding="{Binding Speed, StringFormat=F0}" Width="45"/>
                                            <DataGridTextColumn Header="A" Binding="{Binding Accel, StringFormat=F0}" Width="50"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Сохранить prog" Click="SaveProgramButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                <Button Grid.Column="1" Content="Загрузить prog" Click="LoadProgramButton_Click" Padding="8,3" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="2" Text="Режим:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="3" Width="90" x:Name="ProgramRunModeComboBox" SelectedIndex="0">
                                    <ComboBoxItem Content="Линейно"/>
                                    <ComboBoxItem Content="Цикл"/>
                                </ComboBox>
                                <Button Grid.Column="4" Content="Стоп prog" Click="StopProgramButton_Click" Padding="8,3" Margin="8,0,0,0"/>
                            </Grid>

                            <Border Background="#20252C" BorderBrush="#3B414A" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Операции программы" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="+MoveL" Click="AddMoveLOperationButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="+MoveJ" Click="AddMoveJOperationButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="+Wait" Click="AddWaitOperationButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="+IO" Click="AddIoOperationButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Up" Click="MoveOperationUpButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Dn" Click="MoveOperationDownButton_Click" Padding="8,3" Margin="0,0,6,0"/>
                                        <Button Content="Del" Click="DeleteOperationButton_Click" Padding="8,3"/>
                                    </StackPanel>
                                    <DataGrid x:Name="OperationsGrid" Grid.Row="2" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                                              SelectionMode="Single" Background="#161A1F" Foreground="#E6E6E6"
                                              BorderBrush="#3B414A" SelectionChanged="OperationsGrid_SelectionChanged"
                                              CellEditEnding="OperationsGrid_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="34"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="56"/>
                                            <DataGridTextColumn Header="WP" Binding="{Binding WaypointIndex}" Width="36"/>
                                            <DataGridTextColumn Header="V" Binding="{Binding Speed, StringFormat=F0}" Width="42"/>
                                            <DataGridTextColumn Header="A" Binding="{Binding Accel, StringFormat=F0}" Width="42"/>
                                            <DataGridTextColumn Header="Wait ms" Binding="{Binding WaitMs}" Width="62"/>
                                            <DataGridTextColumn Header="IO" Binding="{Binding IoChannel}" Width="58"/>
                                            <DataGridTextColumn Header="Val" Binding="{Binding IoValue}" Width="38"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <TextBlock Text="J1" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J1-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint1Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J1+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="J2" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J2-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint2Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J2+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="J3" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J3-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint3Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J3+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="J4" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J4-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint4Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J4+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="J5" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J5-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint5Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J5+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="J6" Margin="0,6,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="-" Tag="J6-" Click="JogNudgeButton_Click" Width="30" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" x:Name="Joint6Slider" Minimum="-180" Maximum="180" ValueChanged="JointSlider_ValueChanged"/>
                                <Button Grid.Column="2" Content="+" Tag="J6+" Click="JogNudgeButton_Click" Width="30" Margin="6,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- ==================== OUTPUT ==================== -->
        <Border Grid.Row="2" Background="#1A1D22" BorderBrush="#3A3D42" BorderThickness="0,1,0,1" Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Output / Journal" Foreground="#AAB2BD" Margin="0,0,0,6"/>
                <ListBox x:Name="OutputListBox" Grid.Row="1" Background="#101317" Foreground="#D7DEE8" BorderBrush="#3A3D42"
                         FontFamily="Segoe UI" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ==================== КОМАНДНАЯ СТРОКА ==================== -->
        <Border Grid.Row="3" Background="#303030" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Команда:" VerticalAlignment="Center" 
                           Foreground="#AAAAAA" Margin="0,0,8,0"/>
                
                <TextBox x:Name="CommandLine" Grid.Column="1" 
                         Background="#1E1E1E" Foreground="White"
                         FontFamily="Segoe UI"
                         BorderBrush="#505050"
                         KeyDown="CommandLine_KeyDown"
/>
            </Grid>
        </Border>
        
        <!-- ==================== СТАТУСНАЯ СТРОКА ==================== -->
        <StatusBar Grid.Row="4" Background="#252525" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="|"/>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Слой: " Foreground="#AAAAAA"/>
                    <TextBlock x:Name="CurrentLayerText" Text="0" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Цвет: " Foreground="#AAAAAA"/>
                    <Rectangle x:Name="CurrentColorIndicator" Width="16" Height="16" 
                               Fill="White" Margin="4,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORTHO: " Foreground="#AAAAAA"/>
                    <TextBlock x:Name="OrthoStatus" Text="ВЫКЛ" 
                               Foreground="{StaticResource AccentRed}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Цикл: " Foreground="#AAAAAA"/>
                    <TextBlock x:Name="CycleTimeText" Text="—" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="IK: " Foreground="#AAAAAA"/>
                    <TextBlock x:Name="IkStatusText" Text="OK" Foreground="{StaticResource AccentGreen}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ПРИВЯЗКИ: " Foreground="#AAAAAA"/>
                    <TextBlock x:Name="SnapStatus" Text="ВКЛ" 
                               Foreground="{StaticResource AccentGreen}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
